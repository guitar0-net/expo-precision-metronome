{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],

  "minimumReleaseAge": "3 days",
  "prConcurrentLimit": 10,

  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "minimumReleaseAge": "0 days"
  },

  "schedule": ["before 6am on Saturday"],

  "labels": ["dependencies"],
  "commitMessagePrefix": "chore(deps):",
  "rebaseWhen": "conflicted",
  "separateMajorMinor": true,
  "major": {
    "labels": ["dependencies", "breaking-change"]
  },

  "packageRules": [
    {
      "matchDepTypes": ["devDependencies"],
      "labels": ["dependencies", "npm"]
    },

    {
      "description": "expo, react-native, and react must stay in sync per the Expo SDK compatibility table. Wait 14 days before raising a PR.",
      "matchPackageNames": [
        "expo",
        "expo-module-scripts",
        "/^expo-/",
        "/^@expo\\//",
        "react-native",
        "react",
        "@types/react",
        "@types/react-native"
      ],
      "groupName": "expo-sdk",
      "minimumReleaseAge": "14 days",
      "labels": ["dependencies", "expo-sdk"]
    },

    {
      "matchPackageNames": [
        "@commitlint/cli",
        "@commitlint/config-conventional",
        "husky",
        "lint-staged"
      ],
      "groupName": "git-hooks-tooling"
    },

    {
      "matchPackageNames": [
        "eslint",
        "/^eslint-/",
        "/^@typescript-eslint\\//",
        "eslint-config-universe",
        "prettier"
      ],
      "groupName": "linting"
    },

    {
      "matchPackageNames": ["typescript", "ts-node", "tslib"],
      "groupName": "build-tooling"
    },

    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "labels": ["dependencies", "ci"]
    }
  ]
}
